				{
					"name": "login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Add this script to the \"Tests\" tab of your Postman request\r",
									"\r",
									"// Parse the response JSON\r",
									"const responseJson = pm.response.json();\r",
									"\r",
									"// Extract the access token from the response\r",
									"const accessToken = responseJson.accessToken;\r",
									"\r",
									"// Set the access token as a collection/environment variable\r",
									"pm.collectionVariables.set(\"accessToken\", accessToken);\r",
									"\r",
									"// Optional: Also set as environment variable (if you prefer environment over collection)\r",
									"// pm.environment.set(\"accessToken\", accessToken);\r",
									"\r",
									"// Optional: Set as global variable (available across all collections)\r",
									"// pm.globals.set(\"accessToken\", accessToken);\r",
									"\r",
									"// Optional: Log the token for debugging\r",
									"console.log(\"Access Token saved:\", accessToken);\r",
									"\r",
									"// Optional: Set token with Bearer prefix for Authorization header\r",
									"// pm.collectionVariables.set(\"authToken\", \"Bearer \" + accessToken);"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
